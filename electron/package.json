{
  "name": "kafclaw-desktop",
  "version": "0.1.0",
  "description": "KafClaw Desktop - AI Assistant with three operation modes",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "dev:electron": "sleep 3 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.8",
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  },
  "engines": {
    "node": ">=24.9.0",
    "npm": ">=11.6.0"
  },
  "volta": {
    "node": "24.9.0",
    "npm": "11.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kamir/KafClaw.git"
  },
  "author": {
    "name": "kamir",
    "email": "kamir@users.noreply.github.com"
  },
  "license": "MIT"
}
